# Cache rules for Cloudflare Workers static assets.
# Order matters: later, more specific rules override earlier ones.
# NOTE: /assets/art/*, /assets/collections/*, /assets/scripts/* and
# /assets/tokens/* are served by the Worker (R2 first), which sets its own
# Cache-Control — rules here only apply to files served from the repo.

# HTML / CSS / JS: always revalidate so edits show on a normal refresh
/*.html
  Cache-Control: no-cache, must-revalidate
/assets/*.css
  Cache-Control: no-cache, must-revalidate
/assets/*.js
  Cache-Control: no-cache, must-revalidate

# Character art & other repo images: revalidate so updated art shows immediately
/assets/*.png
  Cache-Control: no-cache, must-revalidate
/assets/*.jpg
  Cache-Control: no-cache, must-revalidate
/assets/art/*
  Cache-Control: no-cache, must-revalidate

# Official role icons never change — cache long
/assets/icons/*
  Cache-Control: public, max-age=31536000, immutable
/assets/jinx-icons/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts rarely change and are large — cache long
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Pyodide runtime + wheels (Token Tool): pinned version, contents never change
/assets/pyodide/*
  Cache-Control: public, max-age=31536000, immutable

# Token toolkit files: fetched with a ?v= from the manifest, safe to cache long
/assets/tokens/*
  Cache-Control: public, max-age=31536000, immutable

# The token manifest must always be fresh (it carries the version)
/assets/tokens/manifest.json
  Cache-Control: no-cache, must-revalidate
