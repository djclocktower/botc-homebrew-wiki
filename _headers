# Cache rules for Cloudflare static assets
# CSS/JS: always revalidate so edits show on a normal refresh (no hard-refresh)
/assets/*.css
  Cache-Control: no-cache, must-revalidate
/assets/*.js
  Cache-Control: no-cache, must-revalidate

# HTML: always revalidate
/*.html
  Cache-Control: no-cache, must-revalidate

# Art images: revalidate so updated art shows immediately (no stale cache)
/assets/art/*.png
  Cache-Control: no-cache, must-revalidate
/assets/art/*.jpg
  Cache-Control: no-cache, must-revalidate

# Other images: revalidate too (covers character art at any path)
/assets/*.png
  Cache-Control: no-cache, must-revalidate
/assets/*.jpg
  Cache-Control: no-cache, must-revalidate

# Fonts rarely change and are large — keep cached
/assets/*.ttf
  Cache-Control: public, max-age=604800
/assets/*.woff2
  Cache-Control: public, max-age=604800
