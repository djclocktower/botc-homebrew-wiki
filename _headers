
# ── Token Tool engine caching (these later rules override the generic ones above) ──
# Pyodide runtime + wheels: pinned to v0.27.7, contents never change — cache for a year
/assets/pyodide/*
  Cache-Control: public, max-age=31536000, immutable

# Token toolkit files: fetched with a ?v= from the manifest, so long caching is safe
/assets/tokens/*
  Cache-Control: public, max-age=31536000, immutable

# The manifest itself must always be fresh (it carries the version)
/assets/tokens/manifest.json
  Cache-Control: no-cache, must-revalidate
